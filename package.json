{
  "name": "rivet-ridge-rally",
  "version": "1.0.0-rc.2",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.17.0",
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24.0.0"
  },
  "scripts": {
    "assets:build": "node scripts/build-hero-bike-rider-assets.mjs && node scripts/build-rival-pack-assets.mjs && node scripts/build-canyon-assets.mjs",
    "assets:verify": "node scripts/verify-hero-bike-rider-assets.mjs && node scripts/verify-rival-pack-assets.mjs && node scripts/verify-canyon-assets.mjs && node scripts/verify-production-art.mjs",
    "dev": "vite",
    "typecheck": "node node_modules/typescript-7/bin/tsc -b --pretty false",
    "lint": "eslint .",
    "notices:build": "node scripts/write-third-party-notices.mjs",
    "prebuild": "npm run assets:verify",
    "perf:measure": "node scripts/performance/measure.mjs",
    "perf:soak": "node scripts/performance/soak.mjs",
    "release:attestation:verify": "node scripts/release-attestation.mjs",
    "release:manifest": "node scripts/release-manifest.mjs",
    "visual:candidate": "node scripts/release-manifest.mjs --profile visual-qa",
    "smoke:production": "node scripts/production-smoke.mjs",
    "test": "vitest run && npm run test:release-manifest && npm run test:release-attestation && npm run test:production-smoke-support",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:production-smoke-support": "node --test scripts/production-smoke-support.test.mjs scripts/production-smoke-flow.test.mjs scripts/service-worker-install.test.mjs",
    "test:release-attestation": "node --test scripts/release-attestation.test.mjs",
    "test:release-manifest": "node --test scripts/release-manifest.test.mjs",
    "visual:capture": "node scripts/capture-visual-review.mjs",
    "visual:promote:canyon": "node scripts/promote-visual-baseline.mjs",
    "build": "npm run typecheck && vite build && npm run notices:build",
    "preview": "vite preview",
    "audit": "npm audit --audit-level=high"
  },
  "dependencies": {
    "dexie": "4.4.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "three": "0.185.1",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@eslint/js": "10.0.1",
    "@gltf-transform/core": "4.4.1",
    "@gltf-transform/extensions": "4.4.1",
    "@gltf-transform/functions": "4.4.1",
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.185.1",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "axe-core": "4.12.1",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "gltf-validator": "2.0.0-dev.3.10",
    "jsdom": "29.1.1",
    "ktx2-encoder": "0.5.3",
    "meshoptimizer": "1.2.0",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "typescript-7": "npm:typescript@7.0.2",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
